<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Readiness Assessment: Engagement Arc</title>
<meta name="description" content="A kickoff reference for the AI Readiness Assessment engagement. Covers the five-phase arc, client responsibilities, the deliverable, and communication expectations.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,300..900,0..100,0..1&family=Geist:wght@300..700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ============================================================
   LOXLEY FRAMEWORK DOCUMENT : TACTICAL VERDANT
   Derived from Capability Brief 01 (Technical Health Assessment
   Framework), the canonical exemplar. Layered with the curated
   evolutions adopted as canonical: dark obsidian footer,
   .callout component, .check-list component.

   When in doubt, the THA HTML is the source of truth.
   ============================================================ */

:root {
  --obsidian: #0F1419;
  --obsidian-soft: #1F2429;
  --obsidian-muted: #4A5159;
  --silver: #C5C9D0;
  --silver-light: #E4E6EA;
  --vellum: #F5F1E8;
  --vellum-deep: #EDE8DC;
  --vellum-warm: #F8F5EE;
  --green: #2D7A4D;
  --green-deep: #1F5A37;
  --green-pale: #E8F0EB;
  --rule: rgba(15, 20, 25, 0.12);
  --rule-soft: rgba(15, 20, 25, 0.06);
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  font-family: "Geist", -apple-system, sans-serif;
  font-weight: 400;
  font-size: 17px;
  line-height: 1.65;
  color: var(--obsidian);
  background: var(--vellum);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.page { max-width: 880px; margin: 0 auto; padding: 0 48px; }

/* ============================================================
   TOPBAR
   ============================================================ */
.topbar {
  border-bottom: 1px solid var(--rule);
  padding: 22px 0;
}

.topbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-family: "Geist Mono", monospace;
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--obsidian-muted);
}

.brand {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--obsidian);
  font-weight: 500;
}

.brand-mark {
  width: 10px;
  height: 10px;
  background: var(--green);
  transform: rotate(45deg);
}

/* ============================================================
   HERO
   Eyebrow: single label preceded by a green decorative line.
   H1: Fraunces 64 with opsz 144 and SOFT axis for warmth.
   Lede: Fraunces 22 light.
   Meta strip: three classifier slots (Document/Practice/Format).
   ============================================================ */
.hero {
  padding: 100px 0 80px;
  border-bottom: 1px solid var(--rule);
}

.hero-eyebrow {
  font-family: "Geist Mono", monospace;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--green-deep);
  margin-bottom: 28px;
  display: flex;
  align-items: center;
  gap: 14px;
}

.hero-eyebrow::before {
  content: "";
  width: 32px;
  height: 1px;
  background: var(--green);
}

.hero h1 {
  font-family: "Fraunces", serif;
  font-weight: 380;
  font-size: 64px;
  line-height: 1.04;
  letter-spacing: -0.02em;
  font-variation-settings: "opsz" 144, "SOFT" 30;
  margin-bottom: 32px;
  color: var(--obsidian);
}

.hero h1 em {
  font-style: italic;
  font-weight: 360;
  font-variation-settings: "opsz" 144, "SOFT" 80;
  color: var(--green-deep);
}

.hero-lede {
  font-family: "Fraunces", serif;
  font-weight: 350;
  font-size: 22px;
  line-height: 1.5;
  color: var(--obsidian-soft);
  max-width: 680px;
  font-variation-settings: "opsz" 24;
}

.hero-meta {
  display: flex;
  gap: 60px;
  margin-top: 56px;
  padding-top: 32px;
  border-top: 1px solid var(--rule-soft);
  font-family: "Geist Mono", monospace;
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--obsidian-muted);
}

.hero-meta div span {
  display: block;
  color: var(--obsidian);
  font-family: "Geist", sans-serif;
  font-size: 13px;
  text-transform: none;
  letter-spacing: 0;
  margin-top: 4px;
  font-weight: 500;
}

/* ============================================================
   SECTIONS
   Eyebrow: muted number, green label.
   H2: Fraunces 40, italicized green-deep emphasis on the load
   bearing clause via <em>.
   ============================================================ */
section {
  padding: 88px 0;
  border-bottom: 1px solid var(--rule);
}

section:last-of-type { border-bottom: none; }

.section-eyebrow {
  font-family: "Geist Mono", monospace;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--green-deep);
  margin-bottom: 20px;
  display: flex;
  align-items: baseline;
  gap: 14px;
}

.section-eyebrow .num {
  color: var(--obsidian-muted);
  font-weight: 500;
}

h2 {
  font-family: "Fraunces", serif;
  font-weight: 380;
  font-size: 40px;
  line-height: 1.12;
  letter-spacing: -0.015em;
  font-variation-settings: "opsz" 72, "SOFT" 40;
  margin-bottom: 36px;
  max-width: 720px;
  color: var(--obsidian);
}

h2 em {
  font-style: italic;
  font-variation-settings: "opsz" 72, "SOFT" 80;
  color: var(--green-deep);
}

h3 {
  font-family: "Fraunces", serif;
  font-weight: 450;
  font-size: 24px;
  line-height: 1.25;
  letter-spacing: -0.01em;
  font-variation-settings: "opsz" 36;
  margin-bottom: 14px;
  color: var(--obsidian);
}

h4 {
  font-family: "Geist", sans-serif;
  font-weight: 600;
  font-size: 13px;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--obsidian);
  margin-bottom: 10px;
}

p {
  font-size: 17px;
  line-height: 1.65;
  color: var(--obsidian-soft);
  margin-bottom: 20px;
  max-width: 720px;
}

p.lede {
  font-family: "Fraunces", serif;
  font-weight: 380;
  font-size: 21px;
  line-height: 1.5;
  color: var(--obsidian);
  margin-bottom: 32px;
  font-variation-settings: "opsz" 24;
}

/* ============================================================
   DOMAIN GRID : for diagnostic-landscape sections
   ============================================================ */
.domain-block { margin-bottom: 64px; }
.domain-block:last-child { margin-bottom: 0; }

.domain-block-title {
  font-family: "Geist Mono", monospace;
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--obsidian);
  padding-bottom: 16px;
  margin-bottom: 32px;
  border-bottom: 2px solid var(--obsidian);
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.domain-block-title .count {
  color: var(--green-deep);
  font-weight: 500;
}

.domains {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px 56px;
}

.domain {
  border-left: 2px solid var(--green);
  padding-left: 24px;
}

.domain-num {
  font-family: "Geist Mono", monospace;
  font-size: 10px;
  letter-spacing: 0.14em;
  color: var(--green-deep);
  margin-bottom: 8px;
  display: block;
}

.domain-name {
  font-family: "Fraunces", serif;
  font-weight: 500;
  font-size: 19px;
  line-height: 1.3;
  margin-bottom: 8px;
  color: var(--obsidian);
  font-variation-settings: "opsz" 24;
}

.domain p {
  font-size: 15px;
  line-height: 1.6;
  margin-bottom: 0;
  color: var(--obsidian-soft);
}

/* ============================================================
   LENS BLOCK : cross-cutting concerns or differentiator sets
   ============================================================ */
.lens-block {
  background: var(--vellum-deep);
  padding: 40px 44px;
  margin-top: 16px;
  border-left: 3px solid var(--obsidian);
}

.lens-block h4 { margin-bottom: 24px; }
.lens-block .lens { margin-bottom: 22px; }
.lens-block .lens:last-child { margin-bottom: 0; }

.lens-name {
  font-family: "Fraunces", serif;
  font-weight: 500;
  font-size: 17px;
  color: var(--obsidian);
  margin-bottom: 4px;
  font-variation-settings: "opsz" 18;
}

.lens p {
  font-size: 15px;
  line-height: 1.55;
  margin-bottom: 0;
}

/* ============================================================
   CONTEXT CARDS : multiple framings of the same engagement
   ============================================================ */
.contexts {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  margin-top: 8px;
}

.context {
  background: var(--vellum);
  padding: 36px 40px;
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 40px;
  align-items: start;
}

.context-label {
  font-family: "Geist Mono", monospace;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--obsidian);
  border-top: 2px solid var(--green);
  padding-top: 12px;
}

.context-label .num {
  color: var(--obsidian-muted);
  display: block;
  margin-bottom: 8px;
  font-weight: 500;
}

.context-name {
  font-family: "Fraunces", serif;
  font-size: 18px;
  font-weight: 500;
  color: var(--obsidian);
  text-transform: none;
  letter-spacing: -0.01em;
  margin-top: 6px;
  font-variation-settings: "opsz" 24;
}

.context-body p {
  font-size: 16px;
  line-height: 1.6;
  margin-bottom: 16px;
}

.context-body p:last-child { margin-bottom: 0; }

.context-meta {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid var(--rule-soft);
  font-family: "Geist Mono", monospace;
  font-size: 11px;
  letter-spacing: 0.08em;
  color: var(--obsidian-muted);
  text-transform: uppercase;
}

.context-meta strong {
  color: var(--green-deep);
  font-weight: 500;
}

/* ============================================================
   TIER TABLE : tiered depth or service-level structures
   ============================================================ */
.tiers {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1px;
  background: var(--rule);
  border: 1px solid var(--rule);
  margin-top: 8px;
}

.tier {
  background: var(--vellum);
  padding: 36px 32px;
  display: flex;
  flex-direction: column;
}

.tier-mark {
  font-family: "Geist Mono", monospace;
  font-size: 11px;
  letter-spacing: 0.14em;
  color: var(--obsidian-muted);
  margin-bottom: 8px;
}

.tier-name {
  font-family: "Fraunces", serif;
  font-size: 32px;
  font-weight: 400;
  margin-bottom: 4px;
  color: var(--obsidian);
  font-variation-settings: "opsz" 48, "SOFT" 30;
  letter-spacing: -0.015em;
}

.tier-duration {
  font-family: "Geist Mono", monospace;
  font-size: 12px;
  color: var(--green-deep);
  margin-bottom: 24px;
  letter-spacing: 0.04em;
}

.tier p {
  font-size: 15px;
  line-height: 1.55;
  margin-bottom: 16px;
}

.tier-output {
  margin-top: auto;
  padding-top: 20px;
  border-top: 1px solid var(--rule-soft);
  font-size: 13px;
  line-height: 1.5;
  color: var(--obsidian);
}

.tier-output strong {
  font-family: "Geist Mono", monospace;
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--green-deep);
  font-weight: 500;
  display: block;
  margin-bottom: 6px;
}

/* ============================================================
   PROCESS STEPS
   80px column, 36px italic Fraunces with SOFT 80 axis
   ============================================================ */
.process { margin-top: 24px; }

.process-step {
  display: grid;
  grid-template-columns: 80px 1fr;
  gap: 32px;
  padding: 28px 0;
  border-bottom: 1px solid var(--rule-soft);
}

.process-step:last-child { border-bottom: none; }

.process-step .step-num {
  font-family: "Fraunces", serif;
  font-size: 36px;
  font-weight: 350;
  color: var(--green-deep);
  line-height: 1;
  font-variation-settings: "opsz" 72, "SOFT" 80;
  font-style: italic;
}

.process-step h3 {
  font-size: 20px;
  margin-bottom: 8px;
}

.process-step p {
  font-size: 16px;
  margin-bottom: 0;
}

/* ============================================================
   CALLOUT BOX : declarative engagement-model statements only
   Not for pricing variables. Not for website-tile patterns.
   Used sparingly, typically once per document.
   ============================================================ */
.callout {
  background: var(--vellum-deep);
  border-left: 3px solid var(--green);
  padding: 28px 32px;
  margin: 28px 0;
  max-width: 560px;
}

.callout-label {
  font-family: "Geist Mono", monospace;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--obsidian);
  margin-bottom: 10px;
}

.callout-headline {
  font-family: "Fraunces", serif;
  font-weight: 500;
  font-size: 22px;
  color: var(--green-deep);
  margin-bottom: 14px;
  line-height: 1.25;
  font-variation-settings: "opsz" 24;
}

.callout-meta {
  display: flex;
  justify-content: space-between;
  font-family: "Geist", sans-serif;
  font-size: 14px;
  color: var(--obsidian-muted);
  border-top: 1px solid var(--rule);
  padding-top: 12px;
}

.callout-meta strong {
  color: var(--obsidian);
  font-weight: 500;
}

/* ============================================================
   CHECK-LIST : green-checkmark scannable lists
   For qualifiers, scope items, selection criteria.
   Not for pricing variables. Not for sequential steps.
   ============================================================ */
.check-list {
  list-style: none;
  padding: 0;
  margin: 0 0 28px 0;
  display: flex;
  flex-direction: column;
  gap: 14px;
  max-width: 720px;
}

.check-list li {
  display: grid;
  grid-template-columns: 24px 1fr;
  gap: 12px;
  align-items: start;
  font-family: "Geist", sans-serif;
  font-size: 16px;
  line-height: 1.55;
  color: var(--obsidian-soft);
}

.check-list li::before {
  content: "✓";
  color: var(--green);
  font-weight: 600;
  font-size: 16px;
  line-height: 1.55;
}

/* ============================================================
   FOOTER : dark obsidian variant (curated as canonical)
   ============================================================ */
footer {
  background: var(--obsidian);
  color: var(--silver);
  padding: 80px 0 48px;
  margin-top: 0;
}

footer .page { max-width: 880px; }

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 60px;
  margin-bottom: 50px;
}

.footer-brand {
  font-family: "Fraunces", serif;
  font-size: 22px;
  font-weight: 450;
  color: var(--vellum);
  margin-bottom: 8px;
  letter-spacing: -0.01em;
  font-variation-settings: "opsz" 24;
}

.footer-tag {
  font-family: "Geist Mono", monospace;
  font-size: 11px;
  letter-spacing: 0.14em;
  color: var(--green);
  text-transform: uppercase;
  margin-bottom: 18px;
}

.footer-grid p {
  font-size: 14px;
  line-height: 1.55;
  margin-bottom: 6px;
  color: var(--silver);
  max-width: none;
}

.footer-col h4 {
  font-family: "Geist Mono", monospace;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.14em;
  margin-bottom: 14px;
  color: var(--silver-light);
  text-transform: uppercase;
}

.footer-col p { font-size: 14px; margin-bottom: 6px; }

.footer-bottom {
  padding-top: 28px;
  border-top: 1px solid rgba(197, 201, 208, 0.18);
  display: flex;
  justify-content: space-between;
  font-family: "Geist Mono", monospace;
  font-size: 10px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--silver);
}

.footer-license {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid rgba(197, 201, 208, 0.10);
  font-family: "Geist", sans-serif;
  font-size: 11px;
  line-height: 1.5;
  color: var(--silver);
  letter-spacing: 0;
  text-transform: none;
}

.footer-license a {
  color: var(--green);
